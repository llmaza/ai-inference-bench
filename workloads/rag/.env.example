# Скопируйте в .env и подставьте значения.
# Локальный Qdrant: URL ниже, QDRANT_API_KEY оставьте пустым.
# Qdrant Cloud: URL и API key из консоли cloud.qdrant.io

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Local embeddings:
# EMBEDDING_MODEL=intfloat/multilingual-e5-large
# EMBEDDING_VECTOR_SIZE=1024
# LOCAL_EMBED_DEVICE=cuda
# LOCAL_EMBED_BATCH_SIZE=16

# Local reranker:
# HF_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# LOCAL_RERANK_DEVICE=cuda

# Local small LLM:
# HF_LLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct
# LOCAL_LLM_DEVICE=cuda

# RAG (rag_pipeline.py), по желанию:
# QDRANT_COLLECTION=labor_code_tk_e5
