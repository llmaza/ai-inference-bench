# Triton model config for the exported RuBERT sequence-classification ONNX model.
# This keeps the setup intentionally simple for Phase A1:
# - ONNX Runtime backend
# - explicit tokenizer-side batching outside Triton
# - no dynamic batching yet, so later Triton batching experiments are easier to isolate

name: "bert_classifier"
backend: "onnxruntime"
max_batch_size: 16

input [
  {
    name: "input_ids"
    data_type: TYPE_INT64
    dims: [ -1 ]
  },
  {
    name: "attention_mask"
    data_type: TYPE_INT64
    dims: [ -1 ]
  },
  {
    name: "token_type_ids"
    data_type: TYPE_INT64
    dims: [ -1 ]
  }
]

output [
  {
    name: "logits"
    data_type: TYPE_FP32
    dims: [ 7 ]
  }
]

version_policy: { latest { num_versions: 1 } }

# The exported model uses dynamic sequence length, so Triton sees:
# - batch dimension handled by max_batch_size
# - token dimension left dynamic via dims: [ -1 ]
#
# Dynamic batching is intentionally omitted here for Phase A1.
# When Triton benchmarking starts, we can add a dynamic_batching block
# and compare Triton scheduling against the manual FastAPI batch path.
