# Triton model config for the exported RuBERT sequence-classification ONNX model.
# Phase A1 now enables a first conservative dynamic-batching setup so we can
# compare Triton scheduling against the earlier no-batching baseline.

name: "bert_classifier"
backend: "onnxruntime"
max_batch_size: 16

input [
  {
    name: "input_ids"
    data_type: TYPE_INT64
    dims: [ -1 ]
  },
  {
    name: "attention_mask"
    data_type: TYPE_INT64
    dims: [ -1 ]
  },
  {
    name: "token_type_ids"
    data_type: TYPE_INT64
    dims: [ -1 ]
  }
]

output [
  {
    name: "logits"
    data_type: TYPE_FP32
    dims: [ 7 ]
  }
]

version_policy: { latest { num_versions: 1 } }

# The exported model uses dynamic sequence length, so Triton sees:
# - batch dimension handled by max_batch_size
# - token dimension left dynamic via dims: [ -1 ]

# First-pass dynamic batching:
# - preferred_batch_size tries to form GPU-friendly batches opportunistically
# - max_queue_delay_microseconds keeps queueing conservative for latency
dynamic_batching {
  preferred_batch_size: [ 4, 8, 16 ]
  max_queue_delay_microseconds: 2000
}
